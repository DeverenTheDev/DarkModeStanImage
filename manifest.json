{
  "manifest_version": 3,
  "name": "DarkModeStanImage",
  "version": "1.0.0",
  "description": "A dark mode extension that does not invert the colors of embedded images.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/spreadsheets/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://docs.google.com/spreadsheets/*"]
    }
  ]
}