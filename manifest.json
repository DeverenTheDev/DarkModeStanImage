{
  "manifest_version": 3,
  "name": "DarkModeStanImage",
  "version": "1.1.0",
  "description": "A universal dark mode extension that does not invert the colors of embedded images.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["<all_urls>"]
    }
  ]
}